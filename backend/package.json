{
  "name": "backend",
  "version": "0.1.0",
  "scripts": {
    "build": "yarn build:all",
    "build:all": "tsc -b && tsc-alias",
    "build:app": "tsc -b ./src && tsc-alias",
    "start": "node ./build/src/index.js",
    "dev": "nodemon -r tsconfig-paths/register ./src/index.ts",
    "clean": "rm -rf ./build ./node_modules"
  },
  "private": true,
  "dependencies": {
    "@fastify/cookie": "11.0.2",
    "@fastify/session": "11.1.1",
    "ajv": "8.17.1",
    "fastify": "5.6.2"
  },
  "devDependencies": {
    "@eslint/js": "9.37.0",
    "@types/node": "24.7.2",
    "eslint": "9.37.0",
    "nodemon": "3.1.11",
    "ts-node": "10.9.2",
    "tsc-alias": "1.8.16",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.46.1"
  }
}
